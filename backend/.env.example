# Copy this file to backend/.env and fill in real keys locally.

# Chat engine selection
AI_CHAT_ENGINE=deepseek
AI_EMBED_ENGINE=ollama

# DeepSeek
AI_DEEPSEEK_BASE=https://api.deepseek.com/v1
AI_DEEPSEEK_KEY=
AI_DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible engine
AI_OPENAI_BASE=https://api.openai.com/v1
AI_OPENAI_KEY=
AI_OPENAI_MODEL=gpt-4o-mini
AI_OPENAI_EMBED_MODEL=text-embedding-3-small

# Local Ollama
AI_OLLAMA_BASE=http://localhost:11434
AI_OLLAMA_MODEL=qwen2.5:7b
AI_OLLAMA_EMBED_MODEL=nomic-embed-text

# PaddleOCR
PADDLEOCR_TOKEN=
PADDLEOCR_MODEL=PP-OCRv5
